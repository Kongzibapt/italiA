#!/bin/sh

CURRENT=$(node -e "process.stdout.write(require('./version.json').version)")
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
NEW_VERSION="$MAJOR.$((MINOR + 1))"

printf '{ "version": "%s" }\n' "$NEW_VERSION" > version.json

# Amend le dernier commit (inclus dans le push, contrairement à un nouveau commit)
git add version.json
git commit --amend --no-edit --no-verify

echo "🔖 v$NEW_VERSION"
